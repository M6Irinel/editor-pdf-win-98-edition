{
  "name": "my-pdf-editor-windows-98-edition",
  "private": true,
  "version": "1.1.3",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder && rmdir /s /q dist",
    "electron:dev": "vite build && set NODE_ENV=development && electron ."
  },
  "build": {
    "appId": "com.mypdfeditor.app",
    "productName": "My Editor PDF",
    "icon": "public/favicon.ico",
    "directories": {
      "output": "app-build"
    },
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/favicon.ico"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs"
    ]
  },
  "dependencies": {
    "98.css": "^0.1.21",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "vite": "^5.0.8"
  }
}
