{
  "name": "my-pdf-editor",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "set NODE_ENV=development && electron .",
    "electron:build": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.mypdfeditor.app",
    "productName": "Mio Editor PDF",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs"
    ]
  },
  "dependencies": {
    "98.css": "^0.1.21",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "vite": "^5.0.8"
  }
}
